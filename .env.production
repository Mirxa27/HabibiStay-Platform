# Production Environment Configuration
# This file contains environment variables for production deployment

# Application Settings
NODE_ENV=production
PORT=3000
HOST=0.0.0.0

# Database Configuration
DATABASE_URL=postgresql://habibistay:${POSTGRES_PASSWORD}@postgres-prod:5432/habibistay
POSTGRES_DB=habibistay
POSTGRES_USER=habibistay
POSTGRES_PASSWORD=your_secure_postgres_password_here

# Redis Configuration
REDIS_URL=redis://redis-prod:6379

# JWT Configuration
JWT_SECRET=your_super_secure_jwt_secret_here_min_32_chars
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_EXPIRES_IN=30d

# OAuth Configuration - Google
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=https://habibistay.com/auth/google/callback

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=1000

# Payment Gateway Configuration - MyFatoorah
MYFATOORAH_API_KEY=your_myfatoorah_api_key_here
MYFATOORAH_BASE_URL=https://api.myfatoorah.com
MYFATOORAH_WEBHOOK_SECRET=your_myfatoorah_webhook_secret_here

# Payment Gateway Configuration - PayPal
PAYPAL_CLIENT_ID=your_paypal_client_id_here
PAYPAL_CLIENT_SECRET=your_paypal_client_secret_here
PAYPAL_MODE=live
PAYPAL_WEBHOOK_ID=your_paypal_webhook_id_here

# Email Configuration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=noreply@habibistay.com
EMAIL_PASS=your_email_app_password_here
EMAIL_FROM=HabibiStay <noreply@habibistay.com>

# File Upload Configuration - Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name_here
CLOUDINARY_API_KEY=your_cloudinary_api_key_here
CLOUDINARY_API_SECRET=your_cloudinary_api_secret_here

# Security Configuration
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
CSRF_SECRET=your_csrf_secret_here
CORS_ORIGIN=https://habibistay.com

# Session Configuration
SESSION_SECRET=your_session_secret_here
SESSION_NAME=habibistay_session
SESSION_SECURE=true
SESSION_HTTP_ONLY=true
SESSION_MAX_AGE=86400000

# SSL Configuration
SSL_CERT_PATH=/etc/ssl/certs/habibistay.crt
SSL_KEY_PATH=/etc/ssl/private/habibistay.key

# Monitoring Configuration
PROMETHEUS_PORT=9090
GRAFANA_USER=admin
GRAFANA_PASSWORD=your_grafana_password_here

# Logging Configuration
LOG_LEVEL=info
LOG_FILE=/app/logs/application.log
ERROR_LOG_FILE=/app/logs/error.log

# Feature Flags
ENABLE_VOICE_INTERFACE=true
ENABLE_DYNAMIC_PRICING=true
ENABLE_CHANNEL_MANAGER=true
ENABLE_PAYMENT_PROCESSING=true
ENABLE_EMAIL_NOTIFICATIONS=true

# API Rate Limiting
API_RATE_LIMIT_WINDOW=15
API_RATE_LIMIT_MAX=100
SEARCH_RATE_LIMIT_MAX=50
BOOKING_RATE_LIMIT_MAX=10

# File Upload Limits
MAX_FILE_SIZE=10485760
MAX_FILES_PER_UPLOAD=10
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/webp,application/pdf

# External API Configuration
CURRENCY_API_KEY=your_currency_api_key_here
WEATHER_API_KEY=your_weather_api_key_here
MAPS_API_KEY=your_google_maps_api_key_here

# Backup Configuration
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_S3_BUCKET=habibistay-backups
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
AWS_REGION=us-east-1

# Content Delivery Network
CDN_URL=https://cdn.habibistay.com
STATIC_ASSETS_URL=https://assets.habibistay.com

# Analytics Configuration
GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
FACEBOOK_PIXEL_ID=your_facebook_pixel_id_here

# Error Tracking
SENTRY_DSN=your_sentry_dsn_here
SENTRY_ENVIRONMENT=production

# Health Check Configuration
HEALTH_CHECK_INTERVAL=30
HEALTH_CHECK_TIMEOUT=10
HEALTH_CHECK_RETRIES=3

# Performance Configuration
NODE_OPTIONS=--max-old-space-size=2048
UV_THREADPOOL_SIZE=16

# Cache Configuration
CACHE_TTL=3600
CACHE_PREFIX=habibistay:
CACHE_MAX_SIZE=100