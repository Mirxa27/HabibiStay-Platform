# Docker ignore file for HabibiStay
# Optimized for minimal image size and security

# Node modules and build artifacts
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Build outputs
dist/
build/
*.tsbuildinfo
.vite/

# Development files
.env
.env.local
.env.development
.env.test
.env.production.local

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Git files
.git/
.gitignore
README.md

# Testing
coverage/
.nyc_output/
*.lcov

# Logs
logs/
*.log

# Runtime data
pids/
*.pid
*.seed
*.pid.lock

# Optional npm cache directory
.npm/

# Optional eslint cache
.eslintcache

# Microbundle cache
.rpt2_cache/
.rts2_cache_cjs/
.rts2_cache_es/
.rts2_cache_umd/

# Optional REPL history
.node_repl_history

# Yarn integrity file
.yarn-integrity

# dotenv environment variables file
.env.example

# parcel-bundler cache (https://parceljs.org/)
.cache/
.parcel-cache/

# next.js build output
.next/

# nuxt.js build output
.nuxt/

# vuepress build output
.vuepress/dist/

# Serverless directories
.serverless/

# FuseBox cache
.fusebox/

# DynamoDB Local files
.dynamodb/

# TernJS port file
.tern-port

# Stores VSCode versions used for testing VSCode extensions
.vscode-test/

# Temporary folders
tmp/
temp/

# Backup files
*.bak
*.backup

# Development database
*.db
*.sqlite
*.sqlite3

# Upload directories (development)
uploads/

# Certificate files
*.pem
*.key
*.crt

# Docker files (to prevent nested builds)
Dockerfile*
docker-compose*.yml
.dockerignore

# CI/CD files
.github/
.gitlab-ci.yml
.travis.yml
.circleci/

# Documentation
docs/
*.md

# Scripts (not needed in container)
scripts/

# Configuration (will be mounted as volumes)
config/