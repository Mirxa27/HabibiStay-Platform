{
  "dependencies": {
    "@hono/zod-validator": "^0.5.0",
    "@radix-ui/react-dialog": "^1.0.5",
    "@radix-ui/react-dropdown-menu": "^2.0.6",
    "@radix-ui/react-select": "^2.0.0",
    "@radix-ui/react-toast": "^1.1.5",
    "@react-email/components": "^0.5.1",
    "@react-email/render": "^1.2.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "clsx": "^2.1.0",
    "cors": "^2.8.5",
    "date-fns": "^3.3.1",
    "express": "^5.1.0",
    "hono": "4.7.7",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.510.0",
    "openai": "^5.20.2",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-hook-form": "^7.49.3",
    "react-router": "^7.5.3",
    "tailwind-merge": "^2.2.1",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.12.0",
    "@eslint/js": "9.25.1",
    "@getmocha/users-service": "^0.0.4",
    "@getmocha/vite-plugins": "latest",
    "@testing-library/jest-dom": "^6.4.6",
    "@testing-library/react": "^14.3.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "22.14.1",
    "@types/react": "19.0.10",
    "@types/react-dom": "19.0.4",
    "@vitejs/plugin-react": "4.4.1",
    "@vitest/coverage-v8": "^1.6.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^8.2.2",
    "dotenv": "^17.2.2",
    "eslint": "9.25.1",
    "eslint-plugin-react-hooks": "5.2.0",
    "eslint-plugin-react-refresh": "0.4.19",
    "globals": "15.15.0",
    "jsdom": "^24.1.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.7.1",
    "typescript": "5.8.3",
    "typescript-eslint": "8.31.0",
    "vite": "^7.1.3",
    "vitest": "^1.6.0",
    "wrangler": "^4.33.0"
  },
  "name": "mocha-app",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "vite",
    "dev:server": "wrangler dev",
    "dev:mock": "concurrently \"npx tsx mock-server.ts\" \"npm run dev:client\"",
    "dev:frontend-only": "npm run dev:client",
    "build": "tsc -b && vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "cf-typegen": "wrangler types",
    "check": "tsc && vite build && wrangler deploy --dry-run",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest --watch",
    "test:security": "vitest run src/test/security-utils.test.ts",
    "test:components": "vitest run src/test/**/*.test.tsx",
    "test:api": "vitest run src/test/api-endpoints.test.ts",
    "test:e2e": "vitest run src/test/e2e-flows.test.tsx",
    "test:all": "npm run test:run && npm run test:coverage",
    "docker:build": "docker build -t habibistay .",
    "docker:build:dev": "docker build -f Dockerfile.dev -t habibistay:dev .",
    "docker:dev": "docker compose --profile dev up -d",
    "docker:prod": "docker compose --profile prod up -d",
    "docker:monitoring": "docker compose --profile monitoring up -d",
    "docker:stop": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "deploy": "./scripts/deploy.sh deploy",
    "deploy:backup": "./scripts/deploy.sh backup",
    "deploy:rollback": "./scripts/deploy.sh rollback",
    "deploy:health": "./scripts/deploy.sh health",
    "setup": "./scripts/setup-environment.sh",
    "validate-env": "node scripts/validate-environment.js",
    "start": "node dist/server/index.js",
    "migrate": "node dist/server/migrate.js",
    "seed": "node dist/server/seed.js"
  },
  "type": "module",
  "version": "0.0.0"
}
