# HabibiStay Environment Configuration Template
# Copy this to .env and fill in your actual values
# Never commit .env with real secrets!

# ========================================
# DATABASE CONFIGURATION
# ========================================
# Local PostgreSQL (dev) or Cloudflare D1 (prod)
DB_URL=postgresql://username:password@localhost:5432/habibistay
DB_POOL_SIZE=10

# Cloudflare D1 Database ID (for production)
D1_DATABASE_ID=your_d1_database_id_here

# ========================================
# CLOUDFLARE WORKERS & STORAGE
# ========================================
# Required for wrangler deployment and R2 image storage
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token
R2_BUCKET_NAME=habibistay-images-bucket
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key

# ========================================
# AUTHENTICATION (@getmocha + JWT)
# ========================================
# OAuth credentials from @getmocha users service
GETMOCHA_CLIENT_ID=your_getmocha_client_id
GETMOCHA_CLIENT_SECRET=your_getmocha_client_secret
GETMOCHA_REDIRECT_URI=http://localhost:5173/auth/callback

# JWT & Session Security
JWT_SECRET=your_super_secure_jwt_secret_at_least_32_characters_long
SESSION_SECRET=your_session_secret_key_for_csrf_protection_32_chars_min
JWT_EXPIRY=24h  # Token lifetime (1d, 7d, etc.)

# ========================================
# PAYMENT GATEWAYS
# ========================================
# MyFatoorah (Primary - Saudi Arabia)
MYFATOORAH_API_KEY=your_myfatoorah_api_key_here
MYFATOORAH_TEST_MODE=true  # false for production
MYFATOORAH_COUNTRY_CODE=SA  # SA, AE, etc.
MYFATOORAH_CURRENCY=SAR

# PayPal (Secondary/International)
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_SANDBOX=true  # false for production
PAYPAL_WEBHOOK_VERIFY_TOKEN=your_paypal_webhook_verify_token

# ========================================
# AI & CHAT SERVICES
# ========================================
# OpenAI (Primary AI provider)
OPENAI_API_KEY=sk-your_openai_api_key_here
AI_MODEL=gpt-4o-mini  # Options: gpt-4o-mini, gpt-4o, gpt-3.5-turbo

# AI Configuration (stored in DB, but defaults here)
AI_TEMPERATURE=0.7
AI_MAX_TOKENS=1000
AI_RATE_LIMIT=10  # Messages per hour per user

# ========================================
# EMAIL & NOTIFICATIONS
# ========================================
# Primary: Resend (recommended for transactional emails)
RESEND_API_KEY=your_resend_api_key_here

# Fallback 1: SendGrid
SENDGRID_API_KEY=your_sendgrid_api_key_here

# Fallback 2: AWS SES
AWS_SES_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_SES_VERIFIED_DOMAIN=your-verified-email-domain.com

# Email From Address (must be verified in providers)
EMAIL_FROM_ADDRESS=noreply@habibistay.com
EMAIL_FROM_NAME=HabibiStay

# ========================================
# CACHE & QUEUES (Redis)
# ========================================
# Redis for rate limiting, sessions, email queue
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=your_redis_password_if_needed

# ========================================
# APPLICATION URLs
# ========================================
# Must match redirect URIs in auth/payment providers
FRONTEND_URL=http://localhost:5173  # Development
# FRONTEND_URL=https://habibistay.com  # Production

API_URL=http://localhost:8787  # Backend API
# API_URL=https://api.habibistay.com  # Production

# ========================================
# SECURITY & RATE LIMITING
# ========================================
# Application environment
NODE_ENV=development  # development, production, test

# Logging level
LOG_LEVEL=info  # debug, info, warn, error

# Rate limiting (requests per minute)
RATE_LIMIT_USER=100  # Regular users
RATE_LIMIT_ADMIN=500  # Admin users
RATE_LIMIT_BURST=10  # Allow bursts

# Security headers
CSP_REPORT_ONLY=false  # true for development testing
HSTS_MAX_AGE=31536000  # 1 year

# File upload limits
MAX_FILE_SIZE=10MB  # Images/documents
ALLOWED_IMAGE_TYPES=jpg,jpeg,png,webp
MAX_IMAGES_PER_PROPERTY=10

# ========================================
# MONITORING & ANALYTICS
# ========================================
# Sentry for error tracking
SENTRY_DSN=your_sentry_dsn_here

# Google Analytics (optional)
GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ========================================
# FEATURE FLAGS (Optional)
# ========================================
# Enable/disable features for gradual rollout
FEATURE_PAYPAL_ENABLED=true
FEATURE_CHANNEL_SYNC_ENABLED=false  # Airbnb etc.
FEATURE_VOICE_CHAT_ENABLED=false
FEATURE_PUSH_NOTIFICATIONS_ENABLED=false

# ========================================
# DEVELOPMENT ONLY
# ========================================
# Disable security checks for local testing (NEVER in production!)
DISABLE_AUTH=false
DISABLE_RATE_LIMITING=true
MOCK_EMAILS=true  # Log to console instead of sending
MOCK_PAYMENTS=false  # Use real payment sandbox

# Database connection timeout (ms)
DB_TIMEOUT=30000

# ========================================
# PRODUCTION NOTES
# ========================================
# For production:
# 1. Set NODE_ENV=production
# 2. Use Cloudflare Workers Secrets: wrangler secret put MYFATOORAH_API_KEY
# 3. Verify all email domains in providers
# 4. Enable HSTS, CSP, and security headers
# 5. Set up webhooks (ngrok for local testing)
# 6. Configure Redis for production caching/queues
# 7. Run npm run deploy for full deployment

# Security Best Practices:
# - Rotate all secrets quarterly
# - Use 1Password/LastPass for key management
# - Enable 2FA on all provider accounts
# - Monitor AuditLogger for suspicious activity
# - Regular security audits with npm audit
