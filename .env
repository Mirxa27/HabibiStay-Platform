# Local Development Environment Configuration

# Application Settings
NODE_ENV=development
PORT=3000

# OpenAI Configuration (required for AI chat)
OPENAI_API_KEY=your_openai_api_key_here

# Payment Gateway Configuration - MyFatoorah (for local testing)
MYFATOORAH_API_KEY=your_myfatoorah_test_api_key_here
MYFATOORAH_API_URL=https://apitest.myfatoorah.com

# Mocha Users Service Configuration
MOCHA_USERS_SERVICE_API_URL=https://users-service.mocha.com
MOCHA_USERS_SERVICE_API_KEY=your_mocha_api_key_here

# Email Configuration (optional for local dev)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=noreply@habibistay.com
EMAIL_PASS=your_email_app_password_here

# Feature Flags for local development
ENABLE_VOICE_INTERFACE=true
ENABLE_DYNAMIC_PRICING=true
ENABLE_CHANNEL_MANAGER=true
ENABLE_PAYMENT_PROCESSING=true
ENABLE_EMAIL_NOTIFICATIONS=false

# Logging
LOG_LEVEL=debug